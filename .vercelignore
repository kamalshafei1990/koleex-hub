# Files Vercel must NOT upload as part of the deployment payload.
# These live in the working tree for local data-import / OCR work
# but are not part of the runtime app — including them in the
# upload bloats it past Vercel's API limits and causes EPIPE /
# "Internal Server Error" responses on `vercel deploy`.
#
# IMPORTANT: All patterns use a leading slash so they are anchored
# to the repo root. Unanchored patterns like `Icons/` were also
# matching `src/components/icons/` on Vercel's ignore matcher,
# which silently dropped 200+ runtime icon files and broke the
# build with "Module not found: @/components/icons/ui/...".

# 2.5 GB of source catalog photos (used to seed Supabase Storage,
# already uploaded via scripts/catalog-import.mjs).
/catalog Photos/

# 77 MB image-only PDF used by the OCR import scripts. Not needed
# at runtime.
/Koleex Catalog 2025.pdf

# Local one-shot scripts — only needed on a workstation.
/scripts/

# Raw icon-library reference assets — 15k+ SVG files from the Flaticon
# uicons set. They push the upload over Vercel's 15,000-file limit and
# nothing in src/ imports from them directly. The actual icons used at
# runtime live in src/components/icons/ as compiled React components.
/Icons/
/Hub icons/
/Jason Icons/

# IDE / editor metadata + intermediate analysis artifacts.
/.claude/
