# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Raw icon-library reference assets (Flaticon uicons set, ~15k SVG
# files). Source: workstation-only reference. The runtime icons used
# by the app live in src/components/icons/ as compiled React
# components. Keeping the raw library untracked keeps deploys under
# Vercel's 15,000-file upload limit.
/Icons/

# Large local-only working assets (catalog photos, source PDFs,
# loose drop-ins). Already in .vercelignore but pin in .gitignore
# too so nobody accidentally commits them.
/catalog Photos/
/Koleex Catalog 2025.pdf
/Omar Machines Photos/
